{
	"compilerOptions": {
		"target": "ESNext",
		"module": "esnext",
		"strict": true,
		"allowJs": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"noImplicitAny": true,
		"sourceMap": true,
		"baseUrl": ".",
		"outDir": "dist",
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"allowImportingTsExtensions": true,
		/* Adding custom path aliases for cleaner imports */
		"paths": {
			"@headbase-app/lib": [
				"./lib/index.ts"
			],
			"@apis/*": [
				"./src/apis/*"
			],
			"@ui/*": [
				"./src/ui/*"
			]
		}
	},
}
