{
  "name": "@headbase-app/web",
  "version": "0.0.0",
  "description": "Supercharge your local markdown files with content types and data views.",
  "private": true,
  "license": "AGPL-3.0-only",
  "keywords": [],
  "author": {
    "name": "Ben Ryder",
    "email": "dev@benryder.me"
  },
  "homepage": "https://github.com/headbase-app/headbase#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/headbase-app/headbase.git"
  },
  "bugs": {
    "url": "https://github.com/headbase-app/headbase/issues"
  },
  "type": "module",
  "scripts": {
    "start": "vite",
    "start:sb": "storybook dev -p 6006",
    "build": "tsc -b && vite build",
    "build:sb": "storybook build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:ui": "vitest --ui",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:setup": "npx playwright install"
  },
  "dependencies": {
    "lit-html": "^3.3.3",
    "lucide-static": "^1.18.0",
    "opfsx": "^0.1.0",
    "pdfjs-dist": "^5.7.284",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
