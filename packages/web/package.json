{
  "name": "@headbase-app/web",
  "version": "0.0.0",
  "description": "Supercharge your local markdown files with content types and data views.",
  "type": "module",
  "scripts": {
    "start": "vite",
    "start:sb": "storybook dev -p 6006",
    "build": "tsc -b && vite build",
    "build:sb": "storybook build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:ui": "vitest --ui",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:setup": "npx playwright install"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "lit-html": "^3.3.2",
    "lucide": "^0.577.0",
    "opfsx": "^0.1.0",
    "pdfjs-dist": "^5.5.207",
    "rxjs": "^7.8.2",
    "sqlocal": "^0.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/web-components-vite": "^10.2.17",
    "@types/node": "^24.10.1",
    "@vitest/browser-playwright": "^4.0.18",
    "happy-dom": "^20.8.3",
    "lightningcss": "^1.32.0",
    "lucide-solid": "^0.577.0",
    "solid-js": "^1.9.11",
    "storybook": "^10.2.15",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
