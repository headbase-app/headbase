{
  "name": "@headbase-app/pwa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "start:sb": "storybook dev -p 6006",
    "build": "tsc -b && vite build",
    "build:sb": "storybook build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:ui": "vitest --ui",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:setup": "npx playwright install"
  },
  "dependencies": {
    "@headbase-app/contracts": "^0.11.0",
    "drizzle-orm": "^0.44.7",
    "lucide-solid": "^0.553.0",
    "opfsx": "^0.1.0",
    "pdfjs-dist": "^5.4.394",
    "rxjs": "^7.8.2",
    "solid-js": "^1.9.10",
    "sqlocal": "^0.16.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.0",
    "@vitest/browser-playwright": "^4.0.8",
    "happy-dom": "^20.0.10",
    "lightningcss": "^1.30.2",
    "storybook": "^10.0.7",
    "storybook-solidjs-vite": "^10.0.5",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.8"
  }
}
